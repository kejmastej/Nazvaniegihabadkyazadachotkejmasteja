void computeConvexHull(
    const vector<R2Point>& points,
    vector<R2Point>& convexHull
) {
    if (points.size() == 0)
        return;
    int n = int(points.size());
    
    //1. Find the left-most point
    int leftPointIdx = 0;
    for (int i = 0; i < n; ++i) {
        if (points[i] < points[leftPointIdx])
            leftPointIdx = i;
    }
    
    R2Point o = points[leftPointIdx];
    //vector<R2Vector> radiusVectors(n - 1);
    vector<R2Vector> radiusVectors;
    //radiusVectors.reserve(n - 1);
    for (int i = 0; i < n; ++i) {
        if (i == leftPointIdx)
            continue;
        radiusVectors.push_back(points[i] - o);
    }
    
    sort(
        radiusVectors.begin(), radiusVectors.end(),
         compareVectors
    );
    
    convexHull.clear();
    convexHull.push_back(o);
    convexHull.push_back(o + radiusVectors[0]);
    if (n < 3)
        return;
    for (int i = 1; i < n - 1; ++i) {
        R2Point t = o + radiusVectors[i];
        R2Vector vLast = convexHull[convexHull.size() - 1] - convexHull[convexHull.size() - 2];
        R2Vector vNew = t - convexHull[convexHull.size() - 1];
        while (convexHull.size() >= 3 && vLast.angle(vNew) <= 0.) {
            convexHull.pop_back();
            vLast = convexHull[convexHull.size() - 1] - convexHull[convexHull.size() - 2];
            vNew = t - convexHull[convexHull.size() - 1];
        }
        // while (convexHull.size() >= 3 && vLast.signed_area(vNew) <= 0) {
        //     convexHull.pop_back();
        //     vLast = convexHull[convexHull.size() - 1] - convexHull[convexHull.size()-2];
        //     vNew = t - convexHull[convexHull.size() - 1];
        // }
        convexHull.push_back(t);
    }
}


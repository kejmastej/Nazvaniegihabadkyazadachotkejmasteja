#include <stdio.h>
#include <math.h>
#include <assert.h>

double f(double);
double f_antider(double);
double simpson(
    double (*f)(double), double a, double b, double dx = 0.001
);

int main() {
    while (true) {
        double a, b, dx;
        printf("Enter a, b, dx:\n");
        if (scanf("%lf%lf%lf", &a, &b, &dx) < 3)
            break;
        double y = simpson(f, a, b, dx);
        double yPresize = f_antider(b) - f_antider(a);
        printf("Integral = %.12f\n", y);
        printf("Presize value = %.12f\n", yPresize);
    }
    return 0;
}

double f(double x) {
    return x*x*x - x - 1.;
}

double f_antider(double x) {
    return x*x*x*x/4. - x*x/2 - x;
}
        
double simpson(
    double (*f)(double), double a, double b, double dx
) {
    assert(dx > 0.);
    int n = int((b - a)/dx);
    if (n == 0)
        n = 1;
    dx = (b - a)/double(n);
    
    double s0 = f(a) + f(b);

    double s1 = 0.;
    double x = a + dx/2.;
    for (int i = 0; i < n; ++i) {
        s1 += f(x);
        x += dx;
    }
    
    double s2 = 0.;
    x = a + dx;
    for (int i = 0; i < n - 1; ++i) {
        s2 += f(x);
        x += dx;
    }
    
    return dx*(s0 + 4.*s1 + 2.*s2)/6.;
}


